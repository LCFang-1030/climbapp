{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  beforeCreate() {\n    console.log('entry beforeCreate');\n    if (!localStorage.getItem('islogin')) {\n      // 沒登入就踢回 staff\n      console.log('islogin is false, back to staffView!!');\n      this.$router.push('/staff');\n    }\n  },\n  mounted() {\n    this.datetime = new Date().toLocaleString('zh-TW', {\n      hour12: false\n    });\n  },\n  data() {\n    return {\n      x: this.$route.query.x,\n      datetime: '',\n      num_id: '0',\n      phone: '123456789',\n      equipment: [],\n      ticket_type: null,\n      entry_record: {\n        datetime: '',\n        ticket_type: null,\n        equipment: []\n      },\n      islogout: false\n    };\n  },\n  methods: {\n    Setlogout() {\n      localStorage.removeItem('islogin');\n      this.$router.push('/staff');\n    }\n  },\n  computed: {\n    price_total() {\n      const ticketPriceMap = {\n        0: 250,\n        1: 300,\n        2: 200,\n        3: 0\n      };\n      const equipmentPriceMap = {\n        0: 100,\n        // 鞋子\n        1: 50,\n        // 主繩\n        2: 70,\n        // 吊帶\n        3: 80 // 粉袋\n      };\n      let total = ticketPriceMap[this.ticket_type] || 0;\n      this.equipment.forEach(i => {\n        total += equipmentPriceMap[i] || 0;\n      });\n      return total;\n    }\n  },\n  watch: {}\n};","map":{"version":3,"names":["beforeCreate","console","log","localStorage","getItem","$router","push","mounted","datetime","Date","toLocaleString","hour12","data","x","$route","query","num_id","phone","equipment","ticket_type","entry_record","islogout","methods","Setlogout","removeItem","computed","price_total","ticketPriceMap","equipmentPriceMap","total","forEach","i","watch"],"sources":["/Users/l.cfang/Desktop/climb-gym/frontend/src/views/EntryView.vue"],"sourcesContent":["\n<template>\n  <div class=\"entry\">\n    <h1>This is an entry page</h1>\n\n    <h4>datetime: {{ datetime }}</h4>\n    <h4>num_id: {{ num_id }} &nbsp; <input type=\"text\" v-model.trim=\"num_id\" /></h4>\n    <h4>phone: {{ phone }}</h4>\n\n    <div>\n    checkbox: {{ equipment }} &nbsp;&nbsp;\n      <input type=\"checkbox\" value=\"0\" v-model=\"equipment\" /> 岩鞋\n      <input type=\"checkbox\" value=\"1\" v-model=\"equipment\" /> 主繩\n      <input type=\"checkbox\" value=\"2\" v-model=\"equipment\" /> 吊帶\n      <input type=\"checkbox\" value=\"3\" v-model=\"equipment\" /> 粉袋\n    </div>\n\n    <div>\n    ticket: {{ ticket_type }} &nbsp;&nbsp;\n      <input type=\"radio\" value=\"0\" v-model=\"ticket_type\" /> 平日單次\n      <input type=\"radio\" value=\"1\" v-model=\"ticket_type\" /> 假日單次\n      <input type=\"radio\" value=\"2\" v-model=\"ticket_type\" /> 星光\n      <input type=\"radio\" value=\"3\" v-model=\"ticket_type\" /> 長期票\n      <!-- <input type=\"radio\" value=\"3\" v-model=\"ticket_type\" /> 月票\n      <input type=\"radio\" value=\"4\" v-model=\"ticket_type\" /> 季票\n      <input type=\"radio\" value=\"5\" v-model=\"ticket_type\" /> 半年票 -->\n    </div>\n   \n    <div>price: {{ price_total }}</div>\n\n    <hr />\n    entry_record: {{ entry_record }}\n    {{ islogout }}\n    <button @click=\"Setlogout()\"> logout </button>\n\n  </div>\n</template>\n\n<script>\nexport default {\n  beforeCreate() {\n    console.log('entry beforeCreate');\n\n    if (!localStorage.getItem('islogin')) {\n      // 沒登入就踢回 staff\n      console.log('islogin is false, back to staffView!!');\n      this.$router.push('/staff');\n    }\n  },\n\n  mounted() {\n    this.datetime = new Date().toLocaleString('zh-TW', { hour12: false });\n\n  },\n\n  data() {\n    return {\n      x: this.$route.query.x,\n\n      datetime: '',\n      num_id: '0',\n      phone: '123456789',\n      equipment: [],\n      ticket_type: null,\n      entry_record: {\n        datetime: '',\n        ticket_type: null,\n        equipment: [],\n      },\n      islogout: false,\n    }\n  },\n\n  methods: {\n    Setlogout() {\n      localStorage.removeItem('islogin');\n      this.$router.push('/staff');\n    },\n  },\n\n  computed: {\n    price_total() {\n      const ticketPriceMap = {\n        0: 250,\n        1: 300,\n        2: 200,\n        3: 0,\n      };\n\n      const equipmentPriceMap = {\n        0: 100, // 鞋子\n        1: 50,  // 主繩\n        2: 70,  // 吊帶\n        3: 80,  // 粉袋\n      };\n\n      let total = ticketPriceMap[this.ticket_type] || 0;\n\n      this.equipment.forEach(i => {\n        total += equipmentPriceMap[i] || 0;\n      });\n\n      return total;\n    },\n\n  },\n\n  watch: {\n\n  },\n\n}\n</script>"],"mappings":";;;AAuCA,eAAe;EACbA,YAAYA,CAAA,EAAG;IACbC,OAAO,CAACC,GAAG,CAAC,oBAAoB,CAAC;IAEjC,IAAI,CAACC,YAAY,CAACC,OAAO,CAAC,SAAS,CAAC,EAAE;MACpC;MACAH,OAAO,CAACC,GAAG,CAAC,uCAAuC,CAAC;MACpD,IAAI,CAACG,OAAO,CAACC,IAAI,CAAC,QAAQ,CAAC;IAC7B;EACF,CAAC;EAEDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,QAAO,GAAI,IAAIC,IAAI,CAAC,CAAC,CAACC,cAAc,CAAC,OAAO,EAAE;MAAEC,MAAM,EAAE;IAAM,CAAC,CAAC;EAEvE,CAAC;EAEDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,CAAC,EAAE,IAAI,CAACC,MAAM,CAACC,KAAK,CAACF,CAAC;MAEtBL,QAAQ,EAAE,EAAE;MACZQ,MAAM,EAAE,GAAG;MACXC,KAAK,EAAE,WAAW;MAClBC,SAAS,EAAE,EAAE;MACbC,WAAW,EAAE,IAAI;MACjBC,YAAY,EAAE;QACZZ,QAAQ,EAAE,EAAE;QACZW,WAAW,EAAE,IAAI;QACjBD,SAAS,EAAE;MACb,CAAC;MACDG,QAAQ,EAAE;IACZ;EACF,CAAC;EAEDC,OAAO,EAAE;IACPC,SAASA,CAAA,EAAG;MACVpB,YAAY,CAACqB,UAAU,CAAC,SAAS,CAAC;MAClC,IAAI,CAACnB,OAAO,CAACC,IAAI,CAAC,QAAQ,CAAC;IAC7B;EACF,CAAC;EAEDmB,QAAQ,EAAE;IACRC,WAAWA,CAAA,EAAG;MACZ,MAAMC,cAAa,GAAI;QACrB,CAAC,EAAE,GAAG;QACN,CAAC,EAAE,GAAG;QACN,CAAC,EAAE,GAAG;QACN,CAAC,EAAE;MACL,CAAC;MAED,MAAMC,iBAAgB,GAAI;QACxB,CAAC,EAAE,GAAG;QAAE;QACR,CAAC,EAAE,EAAE;QAAG;QACR,CAAC,EAAE,EAAE;QAAG;QACR,CAAC,EAAE,EAAE,CAAG;MACV,CAAC;MAED,IAAIC,KAAI,GAAIF,cAAc,CAAC,IAAI,CAACR,WAAW,KAAK,CAAC;MAEjD,IAAI,CAACD,SAAS,CAACY,OAAO,CAACC,CAAA,IAAK;QAC1BF,KAAI,IAAKD,iBAAiB,CAACG,CAAC,KAAK,CAAC;MACpC,CAAC,CAAC;MAEF,OAAOF,KAAK;IACd;EAEF,CAAC;EAE