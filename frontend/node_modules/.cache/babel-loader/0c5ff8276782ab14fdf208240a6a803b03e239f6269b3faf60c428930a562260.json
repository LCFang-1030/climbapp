{"ast":null,"code":"export default {\n  name: 'AppCard'\n};","map":{"version":3,"names":["name"],"sources":["/Users/l.cfang/Desktop/climb-gym/frontend/src/components/AppCard.vue"],"sourcesContent":["<!-- 上層透過slot傳入畫面結構/HTML -->\n<!-- 子元件只負責「框架 / 版型」, 內容完全由父元件決定 -->\n<!-- Slots適合版型固定、內容變化很大的元件 -->\n\n<template>\n  <div>\n    <slot></slot>\n    <slot name=\"header\">header</slot>\n    <slot name=\"content\">content</slot>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'AppCard'\n};\n</script>"],"mappings":"AAaA,eAAe;EACbA,IAAI,EAAE;AACR,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}